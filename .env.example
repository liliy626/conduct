# Upstream model keys
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
GLM_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# OpenWebUI / gateway auth
# Each gateway API key can map to one school schema.
GATEWAY_API_KEYS=key_a,key_a_raw,key_a_ddl,key_b,key_b_raw,key_b_ddl,key_c,key_policy
GATEWAY_AUTH_ENABLED=1
GATEWAY_POLICY_API_KEYS=key_policy

# PostgreSQL data source
POSTGRES_DSN=postgresql://yili_user:change_me@127.0.0.1:5432/yili
POSTGRES_STATEMENT_TIMEOUT_MS=8000
DATA_CONTEXT_TIMEOUT_SEC=90

# School schema SQL Agent
SCHOOL_REACT_AGENT_DISABLE_PROVIDER_THINKING=1
SCHOOL_AGENT_NATIVE_MODEL_ID=yili-qwen

# Universal Hub A/B route
# 1 = enable A-rail Plan Cache + B-rail Universal Hub continuation.
# Keep PLAN_CACHE enabled for high-frequency audited school questions.
UNIVERSAL_HUB_GA_ENABLED=1
UNIVERSAL_HUB_PLAN_CACHE_ENABLED=1
UNIVERSAL_HUB_SHADOW_GATEWAY_ENABLED=0

# Optional A/B test: set to yili-deepseek-r1 to use DeepSeek-R1 for the ReAct reasoning phase.
# SCHOOL_AGENT_NATIVE_MODEL_ID=yili-deepseek-r1
# Optional A/B test: set to yili-deepseek-v3 to use DeepSeek-V3/deepseek-chat for the ReAct reasoning phase.
# SCHOOL_AGENT_NATIVE_MODEL_ID=yili-deepseek-v3
# Quality-first default: keep final answer generation on the reasoning model.
# Set to 1 only for A/B latency tests; it can compress answer detail.
SCHOOL_AGENT_FINAL_MODEL_HANDOFF_ENABLED=0
SCHOOL_AGENT_FINAL_MODEL_ID=yili-qwen-fast
SCHOOL_DDL_EMBED_ENABLED=1
SCHOOL_DDL_EMBED_MODEL=embedding-3
SCHOOL_DDL_EMBED_API_KEY_ENV=GLM_API_KEY
SCHOOL_DDL_EMBED_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SCHOOL_DDL_EMBEDDING_SIZE=1024
SCHOOL_RAW_SQL_MAX_ROWS=500
SCHOOL_REACT_DISPLAY_ROW_LIMIT=500
SCHOOL_TRACE_INCLUDE_ROWS=1
SCHOOL_TRACE_MAX_ROWS=200
SCHOOL_DDL_VECTOR_TABLE=ddl_vector_documents
SCHOOL_DDL_RETRIEVER_TOP_K=12
SCHOOL_EVIDENCE_COVERAGE_ENABLED=1
SCHOOL_EVIDENCE_COVERAGE_MAX_TABLES=12
SCHOOL_DDL_MAX_CHARS_PER_DOC=2200
SCHOOL_DDL_RETRIEVER_CACHE_ENABLED=1
SCHOOL_AGENT_STARTUP_DDL_MODE=summary
SCHOOL_AGENT_STARTUP_DDL_MAX_CHARS=1800
SCHOOL_AGENT_STARTUP_DDL_MAX_TABLES=6
SCHOOL_AGENT_STARTUP_CATALOG_MAX_TABLES=80
SCHOOL_AGENT_STARTUP_CATALOG_MAX_CHARS=5000
SCHOOL_DDL_SEARCH_RESPONSE_MODE=compact
SCHOOL_DDL_SEARCH_PREVIEW_MAX_CHARS=1800
SCHOOL_AGENT_DYNAMIC_TOOL_PRUNING_DISABLED=0
SCHOOL_QUERY_EXPERIENCE_CACHE_ENABLED=1
SCHOOL_QUERY_EXPERIENCE_SCHEMA_MODE=source_schema
SCHOOL_QUERY_EXPERIENCE_SCHEMA=
SCHOOL_QUERY_EXPERIENCE_TABLE=sql_history_vector_documents
SCHOOL_QUERY_EXPERIENCE_TOP_K=5
SQL_HISTORY_TOP_K=5
SQL_HISTORY_COMPLEX_TOP_K=8
SQL_HISTORY_MAX_K=10
SQL_HISTORY_VECTOR_DIM=1024
SQL_HISTORY_WRITE_ENABLED=1
SQL_HISTORY_WRITE_REDIS_ENABLED=1
SQL_HISTORY_WRITE_BACKGROUND_FALLBACK=1
SQL_HISTORY_WRITE_STREAM=sql_history:write
GATEWAY_API_KEY_DB_ENABLED=0
GATEWAY_API_KEY_TABLE_SCHEMA=platform
GATEWAY_API_KEY_TABLE=gateway_api_keys
GATEWAY_API_KEY_CACHE_TTL_SEC=60
SCHOOL_SCHEMA_INDEX_ENABLED=1
SCHOOL_SCHEMA_INDEX_MAX_TABLES=400
SCHOOL_SCHEMA_INDEX_MAX_FIELDS_PER_TABLE=160
SCHOOL_SCHEMA_INDEX_CACHE_ENABLED=1
GATEWAY_WEB_SEARCH_ENABLED=0
GATEWAY_PUBLIC_BASE_URL=http://127.0.0.1:8008
GATEWAY_VISUAL_TOOL_MAX_CALLS=1
GATEWAY_TOOL_MAX_CALLS_DEFAULT=16
# Supported values: searxng, bocha, json_post. Bocha is recommended for low-cost Chinese web search.
GATEWAY_WEB_SEARCH_PROVIDER=searxng
# SearXNG example: http://127.0.0.1:8080/search
# Bocha example: https://api.bochaai.com/v1/web-search
GATEWAY_WEB_SEARCH_ENDPOINT=
GATEWAY_WEB_SEARCH_API_KEY=
BOCHA_API_KEY=
BOCHA_COUNT=8
BOCHA_SUMMARY=1
BOCHA_FRESHNESS=noLimit
GATEWAY_WEB_SEARCH_TIMEOUT_SEC=5
GATEWAY_ARTIFACT_DIR=artifacts/gateway
GATEWAY_IMAGE_TOOL_ENABLED=0
GATEWAY_IMAGE_PROVIDER=dashscope
GATEWAY_IMAGE_SIZE=1024x1024
GATEWAY_IMAGE_QWEN_API_KEY_ENV=DASHSCOPE_API_KEY
DASHSCOPE_IMAGE_MODEL=qwen-image-2.0
DASHSCOPE_BASE_HTTP_API_URL=https://dashscope.aliyuncs.com/api/v1
# OpenAI image provider. Common model names include gpt-image-2, gpt-image-1.5, gpt-image-1, gpt-image-1-mini.
GATEWAY_IMAGE_OPENAI_API_KEY_ENV=OPENAI_API_KEY
GATEWAY_IMAGE_OPENAI_MODEL=gpt-image-2
GATEWAY_IMAGE_OPENAI_BASE_URL=https://api.openai.com/v1

# PPT generation
# basic: built-in PPTX renderer; llm/qwen: Qwen creates the slide outline, local renderer writes PPTX.
GATEWAY_SLIDE_PROVIDER=llm
GATEWAY_SLIDE_LLM_MODEL_ID=yili-qwen
GATEWAY_SLIDE_LLM_API_KEY_ENV=DASHSCOPE_API_KEY
GATEWAY_SLIDE_LLM_TIMEOUT_SEC=60
GATEWAY_SLIDE_LLM_MAX_TOKENS=2200
GATEWAY_SLIDE_LLM_MAX_SLIDES=10
GATEWAY_SLIDE_LLM_FALLBACK_TO_BASIC=1

# School trace debugging
SCHOOL_TRACE_ENABLED=1
SCHOOL_TRACE_INCLUDE_SQL=0
GATEWAY_AGENT_STREAM_INCLUDE_SQL=0
SCHOOL_TRACE_INCLUDE_ROWS=0
SCHOOL_TRACE_TTL_SECONDS=3600
SCHOOL_TRACE_STORE_LIMIT=200

# Official policy evidence search
POLICY_VECTOR_ENABLED=1
POLICY_VECTOR_SCHEMA=official_policy
POLICY_VECTOR_MIN_RELEVANCE=0.20
POLICY_VECTOR_TOP_K=5

# Local testing
REQUEST_CACHE_ENABLED=0

# Docker compose server variables
SERVER_POSTGRES_USER=yili_user
SERVER_POSTGRES_PASSWORD=change_me
SERVER_POSTGRES_DB=yili
SERVER_POSTGRES_PORT=5432
GATEWAY_PORT=8008
TZ=Asia/Shanghai
AGENT_JOB_QUEUE_ENABLED=0
REDIS_URL=redis://127.0.0.1:6379/0
AGENT_JOB_GATEWAY_BASE_URL=http://127.0.0.1:8008
AGENT_JOB_QUEUE_STREAM=agent_jobs:queue
AGENT_JOB_WORKER_GROUP=gateway_workers
AGENT_JOB_EVENT_TTL_SECONDS=86400
AGENT_JOB_STREAM_MAXLEN=5000
AGENT_JOB_MAX_CONCURRENCY=200
GATEWAY_AGENT_STREAM_NARRATOR_ENABLED=1
